# ── Required: at least one LLM provider key ─────────────────────────────────

# Recommended: OpenRouter (access to all models via one key)
OPENROUTER_API_KEY=sk-or-...
LLM_MODEL=openai/gpt-4o-mini

# Or: direct OpenAI
# OPENAI_API_KEY=sk-...
# LLM_MODEL=gpt-4o-mini

# Or: direct Anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# LLM_MODEL=claude-sonnet-4-5

# ── Optional: Tool APIs ──────────────────────────────────────────────────────

# Web search (pick one or more)
EXA_API_KEY=
FIRECRAWL_API_KEY=
PARALLEL_API_KEY=

# Image generation
FAL_KEY=

# Cross-session user modeling
HONCHO_API_KEY=

# GitHub (higher rate limits for code tools)
GITHUB_TOKEN=

# ── Optional: Browser automation ─────────────────────────────────────────────
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=

# ── Gateway security ──────────────────────────────────────────────────────────
# Set to false and configure allowlists if you want to restrict access
GATEWAY_ALLOW_ALL_USERS=true

# ── Optional: OpenAI-compatible API server (/v1) ─────────────────────────────
# Exposes an OpenAI-compatible endpoint at <your-railway-url>/v1 for external
# clients (e.g. ElevenLabs, Open WebUI). Auth is via the Bearer token below —
# this is separate from the dashboard's admin login.
#
# The server runs inside the gateway on loopback; server.py proxies /v1/* to it,
# so you do NOT change PORT or expose a second port. Leave host/port as defaults.
# API_SERVER_ENABLED=true
# API_SERVER_KEY=            # REQUIRED. Strong random token, min 8 chars: openssl rand -hex 32
# API_SERVER_MODEL_NAME=hermes-agent
# API_SERVER_HOST=127.0.0.1  # bind loopback (default); the proxy reaches it in-container
# API_SERVER_PORT=8642       # internal only; not exposed directly

# ── Terminal backend ──────────────────────────────────────────────────────────
# Options: local, docker, modal, ssh
TERMINAL_ENV=local
TERMINAL_TIMEOUT=60
